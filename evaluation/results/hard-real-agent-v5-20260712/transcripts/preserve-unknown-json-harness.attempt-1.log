+import json
+import unittest
+
+from settings import set_enabled
+
+
+class SetEnabledTest(unittest.TestCase):
+    def test_preserves_unknown_keys_and_nested_values(self):
+        original = {
+            "enabled": False,
+            "unknown": {"nested": [1, {"value": None}, True]},
+            "label": "keep me",
+        }
+
+        result = set_enabled(json.dumps(original), True)
+
+        self.assertEqual(
+            result,
+            '{\n'
+            '  "enabled": true,\n'
+            '  "unknown": {\n'
+            '    "nested": [\n'
+            '      1,\n'
+            '      {\n'
+            '        "value": null\n'
+            '      },\n'
