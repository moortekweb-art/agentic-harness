assert config.timeout == config.request_timeout
assert config.timeout is config.request_timeout
assert not callable(config.timeout)
env = dict(
    line.split(\"=\", 1)
    for line in Path(\"example.env\").read_text().splitlines()
    if line and not line.startswith(\"#\")
)
assert env[\"REQUEST_TIMEOUT\"] == str(config.request_timeout)
assert \"TIMEOUT\" not in env
print(\"verification: all focused assertions passed\")
